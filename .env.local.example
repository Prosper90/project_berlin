# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps (address autocomplete + map display)
# Enable: Maps JavaScript API, Maps Embed API, Maps Static API
# Restrict key to your domain in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Resend (email notifications)
# Sign up at https://resend.com → API Keys → Create key
# Verify your domain at Resend → Domains → Add Domain
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Berlin Blockchain Events <notifications@yourdomain.com>
